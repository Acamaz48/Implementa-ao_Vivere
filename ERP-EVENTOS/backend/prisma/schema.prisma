generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 📋 DOMÍNIO DE ENUMS (DICIONÁRIO DE DADOS)
// ==========================================

enum UserRole {
  PRODUCAO
  GALPAO
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

// Representa a Máquina de Estados da Ordem de Serviço
enum ServiceOrderStatus {
  DRAFT // Criação inicial, rascunho
  ACTIVE // Enviada ao galpão para separação
  PENDING // Devolvida do galpão (aguardando revisão/ajuste)
  RETURNED // Devolvida do evento (aguardando revisão/ajuste)
  READY // Pronta/Aprovada para uso
  CANCELED // Cancelada
}

enum ServiceOrderItemStatus {
  ADDED
  REMOVED
}

// Ciclo de Vida do Ativo Físico individual
enum PhysicalItemStatus {
  AVAILABLE // Disponível no galpão
  RESERVED // Separado/em uso em uma Ordem de Serviço
  MAINTENANCE // Quebrado / Em manutenção
  REMOVED // Descartado / Perdido
}

// ==========================================
// 🧑 DOMÍNIO DE USUÁRIOS E ACESSOS
// ==========================================

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  password     String
  name         String
  isVerified   Boolean    @default(false)
  otpCode      String?
  otpExpires   DateTime?
  refreshToken String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  role         UserRole   @default(PRODUCAO)
  status       UserStatus @default(ACTIVE)

  serviceOrders  ServiceOrder[]
  reviewedOrders ServiceOrder[] @relation("OrderReviewer")
}

// ==========================================
// 📅 DOMÍNIO DE EVENTOS E OPERAÇÃO
// ==========================================

model Event {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  status    String
  createdAt DateTime @default(now())
  addressId String

  address       Address        @relation(fields: [addressId], references: [id])
  serviceOrders ServiceOrder[]
}

model Address {
  id        String  @id @default(uuid())
  street    String?
  number    String?
  city      String?
  state     String?
  zipCode   String?
  latitude  Float?
  longitude Float?

  events           Event[]
  operationalUnits OperationalUnit[]
}

model OperationalUnit {
  id        String   @id @default(uuid())
  name      String
  addressId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  address       Address?           @relation(fields: [addressId], references: [id])
  items         ServiceOrderItem[]
  physicalItems PhysicalItem[] // Ativos armazenados nesta unidade
}

// ==========================================
// 🛠️ DOMÍNIO DE ORDENS DE SERVIÇO (CORE)
// ==========================================

model ServiceOrder {
  id           String             @id @default(uuid())
  eventId      String
  userId       String
  createdAt    DateTime           @default(now())
  missingItems Json?
  checked      Boolean             @default(false)
  unavailable  Boolean            @default(false)
  supplier     String?
  updatedAt    DateTime           @updatedAt
  status       ServiceOrderStatus @default(DRAFT)
  observation  String?
  reviewedAt   DateTime?
  reviewedById String?
  reviewedBy   User?              @relation("OrderReviewer", fields: [reviewedById], references: [id])

  event Event              @relation(fields: [eventId], references: [id])
  user  User               @relation(fields: [userId], references: [id])
  items ServiceOrderItem[]
}

model ServiceOrderItem {
  id                String                 @id @default(uuid())
  serviceOrderId    String
  materialId        String
  quantity          Int
  checked           Boolean                @default(false)
  unavailable       Boolean                @default(false)
  createdAt         DateTime               @default(now())
  operationalUnitId String
  status            ServiceOrderItemStatus @default(ADDED)
  updatedAt         DateTime               @updatedAt

  material        Material        @relation(fields: [materialId], references: [id])
  operationalUnit OperationalUnit @relation(fields: [operationalUnitId], references: [id])
  serviceOrder    ServiceOrder    @relation(fields: [serviceOrderId], references: [id])
  physicalItems   PhysicalItem[]

  // Índices otimizados para joins frequentes com materiais e OS
  @@index([serviceOrderId])
  @@index([materialId])
  @@index([operationalUnitId])
  @@index([status])
}

// ==========================================
// 📦 DOMÍNIO DE ESTOQUE E MATERIAIS
// ==========================================

model MaterialCategory {
  id        String     @id @default(uuid())
  name      String     @unique
  materials Material[]
}

model Material {
  id         String @id @default(uuid())
  name       String
  categoryId String
  stock      Int    @default(0) // Quantidade em massa (ex: parafusos)

  movements     InventoryMovement[]
  category      MaterialCategory            @relation(fields: [categoryId], references: [id])
  orderItems    ServiceOrderItem[]
  templates     StructureMaterialTemplate[]
  physicalItems PhysicalItem[] // Relação 1:N (1 Catálogo para N Itens Físicos etiquetados)

  @@unique([name, categoryId])
}

// NOVO: Gestão unitária/serializada de ativos
model PhysicalItem {
  id                 String             @id @default(uuid()) // Usado para Código de Barras / QR Code
  materialId         String
  operationalUnitId  String
  serviceOrderItemId String? // Vinculação temporária quando despachado para OS
  status             PhysicalItemStatus @default(AVAILABLE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  material         Material          @relation(fields: [materialId], references: [id])
  operationalUnit  OperationalUnit   @relation(fields: [operationalUnitId], references: [id])
  serviceOrderItem ServiceOrderItem? @relation(fields: [serviceOrderItemId], references: [id])

  // Índices vitais para escaneamento em massa no galpão
  @@index([materialId])
  @@index([operationalUnitId])
  @@index([serviceOrderItemId])
  @@index([status])
}

model InventoryMovement {
  id         String   @id @default(uuid())
  materialId String
  type       String
  quantity   Int
  date       DateTime @default(now())

  material Material @relation(fields: [materialId], references: [id])
}

// ==========================================
// 🏗️ DOMÍNIO DE ESTRUTURAS (KITS)
// ==========================================

model StructureType {
  id         String      @id @default(uuid())
  name       String      @unique
  structures Structure[]
}

model Structure {
  id              String @id @default(uuid())
  structureTypeId String
  name            String

  type      StructureType               @relation(fields: [structureTypeId], references: [id])
  templates StructureMaterialTemplate[]
}

model StructureMaterialTemplate {
  id          String @id @default(uuid())
  structureId String
  materialId  String
  quantity    Int

  material  Material  @relation(fields: [materialId], references: [id])
  structure Structure @relation(fields: [structureId], references: [id])

  @@unique([structureId, materialId])
}
